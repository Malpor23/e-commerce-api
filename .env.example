# ─────────────────────────────────────────────
#  App
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ─────────────────────────────────────────────
#  Database
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=ecommerce
DB_SYNC=true
DB_LOGGING=true

# ─────────────────────────────────────────────
#  pgAdmin (optional, only with --profile tools)
# ─────────────────────────────────────────────
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin